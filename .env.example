# Copy to `.env` (gitignored) to run Kiln locally.
# The Anthropic key lives ONLY here / in the service — it never reaches the browser (golden invariant #3).

# --- Required: the model key (read by apps/service and apps/web/functions) ---
# Set ONE of these. Anthropic direct (default):
KILN_ANTHROPIC_API_KEY=sk-ant-...
# (Legacy alias, still accepted for back-compat: VBD_ANTHROPIC_API_KEY — prefer the KILN_ name.)
# ...OR route generation through Langdock — an EU-resident, governed, multi-provider gateway that
# exposes an Anthropic-native Messages endpoint, so the same SDK is used (Bearer auth + base URL swap;
# EU data residency, audit/governance). If set, it takes precedence over KILN_ANTHROPIC_API_KEY.
# KILN_LANGDOCK_API_KEY=
# KILN_LANGDOCK_BASE_URL=https://api.langdock.com/anthropic/eu/v1   # or .../anthropic/us/v1

# --- Optional: alternative engines (open-source builds) — OpenAI-compatible gateways ---
# Anthropic stays the default/preferred engine. Set either of these to ALSO offer it in Studio's
# Settings → Engine dropdown (you then pick provider + model + effort per project, in-app). The key
# stays server-side; the browser only names the engine. Web research + the AI interview remain
# Anthropic-only (they use Anthropic-native features).
# OpenRouter — hosted gateway to 250+ models (openrouter.ai). Any model slug works via the in-app box.
# KILN_OPENROUTER_API_KEY=sk-or-...
# KILN_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# omniroute — self-hosted local proxy (github.com/diegosouzapw/omniroute). Connect providers in its
# dashboard first; use its routing aliases (auto, auto/coding, …) or any provider-prefixed model id.
# KILN_OMNIROUTE_API_KEY=
# KILN_OMNIROUTE_BASE_URL=http://localhost:20128/v1

# --- Service (apps/service) ---
# Port the standalone Node API listens on. The web app's dev default targets this.
PORT=8787

# --- Web (apps/web) — build-time, client-side ---
# Where the browser sends /api calls. Leave UNSET for:
#   • Vercel/production → same-origin serverless functions ("")
#   • local dev         → http://localhost:8787 (the service above)
# Set it only to point the SPA at a non-default service origin.
# VITE_SERVICE_URL=http://localhost:8787

# --- Hosted deployment (only for a public/keyed instance, e.g. kilnstudio.app / demo.kilnstudio.app) ---
# Studio lock — set on the SERVER (your host's env vars, e.g. Vercel) to passphrase-protect a hosted,
# keyed instance: every /api call then requires this token (users enter it once, it's kept in their
# browser). Leave UNSET for a private or local instance. This is how kilnstudio.app is gated.
# KILN_STUDIO_TOKEN=
# Public-demo mode — set at BUILD time (client flag) to show the "public demo" banner and signal that
# real AI generation is disabled (a keyless, public demo). This is how demo.kilnstudio.app is built.
# VITE_PUBLIC_DEMO=1

# --- Optional: the "verify" sandbox (apps/service → the Docker verifier in verifier/) ---
# KILN_VERIFY_URL points Kiln at the verifier service. Local: http://localhost:8900
# KILN_VERIFY_SECRET must equal the verifier's VERIFY_SECRET (see verifier/.env.example).
# KILN_VERIFY_URL=http://localhost:8900
# KILN_VERIFY_SECRET=
