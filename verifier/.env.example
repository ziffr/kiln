# Verifier service config. `run.sh` copies this to .env and fills VERIFY_SECRET on first run.
# Everything is variable-based so local → VPS is just editing these values.

# Port the verifier HTTP service listens on.
PORT=8900

# Docker image name/tag built from this dir.
VERIFY_IMAGE=vbd-verifier

# Shared secret VBD must send as the x-verify-secret header. run.sh generates one if empty.
VERIFY_SECRET=

# Hard wall-clock cap per verification (ms).
VERIFY_TIMEOUT_MS=90000

# --- The VBD side (put these in the repo ROOT .env; run.sh can append them for you) ---
# VBD_VERIFY_URL points VBD at this service. Local: http://localhost:8900  ·  VPS: https://verify.yourdomain
# VBD_VERIFY_SECRET must equal VERIFY_SECRET above.
