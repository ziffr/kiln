node_modules/
dist/
*.tsbuildinfo
.DS_Store

# Derived cache — never source of truth (ADR-002)
.vbd/
workspaces/*/.vbd/

# Server-side project data (ADR-006) — user workspaces, not versioned in this repo.
# Root-anchored so it ignores only the server's /data — NOT apps/web/src/data (real source).
/data/

# Local env / secrets — but DO commit the .env.example templates (onboarding docs).
.env
.env.*
!.env.example
!*/.env.example

# Generated execution-engine artifacts (RES-002 export) — not source
/out/

# Vercel serverless-function bundles — esbuild output of apps/web/functions/*.ts, regenerated by
# `build-functions.mjs` during the Vercel build. Source is functions/*.ts; api/*.js is build output.
/apps/web/api/

# Playwright MCP scratch output
.playwright-mcp/
